<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Login</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
	<div class="container mt-5">
		<div class="row justify-content-center">
			<div class="col-md-6">
				<div class="card">
					<div class="card-body">
						<h2 class="card-title text-center mb-4"><%= locals.msg || 'Login page' %></h2>
						<form action="/login" method="post">
							<div class="mb-3">
								<label for="email" class="form-label">Email</label>
								<input type="email" name="email" class="form-control" placeholder="Enter email" required>
							</div>
							<div class="mb-3">
								<label for="password" class="form-label">Password</label>
								<input type="password" name="password" class="form-control" placeholder="Enter password" required>
							</div>
							<div class="d-grid gap-2">
								<button type="submit" name="btn" value="Login" class="btn btn-primary">Login</button>
								<button type="submit" name="btn" value="Cancel" class="btn btn-secondary" formnovalidate>Cancel</button>
								<button type="submit" name="btn" value="signup" class="btn btn-link">Don't have an account? Signup</button>
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
